{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{backend/tests/**,frontend/**,docs/**,.venv/**,.pytest_cache/**}",
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
