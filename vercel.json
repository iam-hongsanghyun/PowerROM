{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/out",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{backend/tests/**,frontend/**,docs/**,archive/**,.venv/**,.pytest_cache/**,**/__pycache__/**,backend/data/ember/**,backend/data/pvgis_cache/**,backend/data/comtrade_cache/**}",
      "maxDuration": 300
    }
  }
}
